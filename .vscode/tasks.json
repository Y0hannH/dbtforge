{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "watch",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "source": "esbuild",
        "applyTo": "closedDocuments",
        "fileLocation": "absolute",
        "pattern": [
          {
            "regexp": "^\\s*(.*):(\\d+):(\\d+):\\s*(error|warning):\\s*(.*)$",
            "file": 1,
            "line": 2,
            "column": 3,
            "severity": 4,
            "message": 5
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\[watch\\] build started",
          "endsPattern": "^\\[watch\\] build finished"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "label": "npm: watch"
    }
  ]
}
